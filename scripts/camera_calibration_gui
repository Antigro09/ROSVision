#!/usr/bin/env python3
"""
Quick camera input calibration GUI for competition-day setup.

Features:
- Live preview from a V4L2 camera.
- Slider controls for common camera properties (exposure, gain, brightness, etc.).
- Resolution/FPS presets for fast switching.
- Save current settings as a YAML snippet.
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Callable, Optional

try:
    import cv2
except ImportError as exc:  # pragma: no cover
    print("ERROR: OpenCV Python bindings are required (python3-opencv).", file=sys.stderr)
    raise SystemExit(1) from exc

try:
    import numpy as np
except ImportError:  # pragma: no cover
    np = None


WINDOW = "ROSVision Camera Calibrator"
RESOLUTION_PRESETS = [
    (640, 480),
    (960, 540),
    (1280, 720),
    (1920, 1080),
]
FPS_PRESETS = [15, 30, 60, 90, 120]


def clamp(value: int, lo: int, hi: int) -> int:
    return max(lo, min(hi, value))


@dataclass
class CameraControl:
    name: str
    trackbar: str
    min_value: int
    max_value: int
    default_value: int
    apply_fn: Callable[[cv2.VideoCapture, int], bool]
    read_fn: Optional[Callable[[cv2.VideoCapture], int]] = None


def apply_prop(prop: int, transform: Callable[[int], float] | None = None) -> Callable[[cv2.VideoCapture, int], bool]:
    def _apply(cap: cv2.VideoCapture, value: int) -> bool:
        out = float(transform(value) if transform else value)
        return bool(cap.set(prop, out))

    return _apply


def read_prop(prop: int, transform: Callable[[float], int] | None = None) -> Callable[[cv2.VideoCapture], int]:
    def _read(cap: cv2.VideoCapture) -> int:
        raw = cap.get(prop)
        return int(transform(raw) if transform else round(raw))

    return _read


def parse_device(device: str) -> int | str:
    return int(device) if device.isdigit() else device


def load_profile(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def save_profile(path: Path, profile: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(profile, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def save_yaml(path: Path, device: str, width: int, height: int, fps: int, values: dict[str, int]) -> None:
    timestamp = dt.datetime.now().isoformat(timespec="seconds")
    yaml = [
        f"# Generated by ROSVision camera_calibration_gui on {timestamp}",
        "camera:",
        f"  device: \"{device}\"",
        f"  width: {width}",
        f"  height: {height}",
        f"  fps: {fps}",
    ]
    for k in ("auto_exposure", "exposure", "gain", "brightness", "contrast", "saturation", "sharpness"):
        if k in values:
            yaml.append(f"  {k}: {values[k]}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(yaml) + "\n", encoding="utf-8")


def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="ROSVision quick camera input calibration GUI")
    p.add_argument("--device", default="0", help="Camera index (e.g. 0) or path (e.g. /dev/video0)")
    p.add_argument("--width", type=int, default=1280, help="Initial capture width")
    p.add_argument("--height", type=int, default=720, help="Initial capture height")
    p.add_argument("--fps", type=int, default=30, help="Initial capture FPS")
    p.add_argument(
        "--save-path",
        default="camera_calibration.yaml",
        help="Output YAML path used when pressing 's'",
    )
    p.add_argument(
        "--profile-path",
        default="~/.config/rosvision/camera_calibration_profile.json",
        help="Autosave profile path (loaded on startup, saved on every change)",
    )
    return p


def main() -> int:
    args = build_arg_parser().parse_args()
    save_path = Path(args.save_path).resolve()
    profile_path = Path(args.profile_path).expanduser().resolve()
    device_key = str(args.device)
    profile_data = load_profile(profile_path)
    device_profile = profile_data.get("profiles", {}).get(device_key, {})

    cap = cv2.VideoCapture(parse_device(args.device), cv2.CAP_V4L2)
    if not cap.isOpened():
        cap = cv2.VideoCapture(parse_device(args.device))
    if not cap.isOpened():
        print(f"ERROR: Could not open camera device '{args.device}'", file=sys.stderr)
        return 1

    initial_width = int(device_profile.get("width", args.width))
    initial_height = int(device_profile.get("height", args.height))
    initial_fps = int(device_profile.get("fps", args.fps))
    cap.set(cv2.CAP_PROP_FRAME_WIDTH, float(initial_width))
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, float(initial_height))
    cap.set(cv2.CAP_PROP_FPS, float(initial_fps))

    controls: list[CameraControl] = [
        CameraControl(
            "auto_exposure",
            "Auto Exposure (0=manual,1=auto)",
            0,
            1,
            0,
            apply_prop(cv2.CAP_PROP_AUTO_EXPOSURE, lambda v: 0.75 if v else 0.25),
            read_prop(cv2.CAP_PROP_AUTO_EXPOSURE, lambda v: 1 if v >= 0.5 else 0),
        ),
        CameraControl(
            "exposure",
            "Exposure",
            -13,
            1,
            -6,
            apply_prop(cv2.CAP_PROP_EXPOSURE),
            read_prop(cv2.CAP_PROP_EXPOSURE),
        ),
        CameraControl("gain", "Gain", 0, 255, 0, apply_prop(cv2.CAP_PROP_GAIN), read_prop(cv2.CAP_PROP_GAIN)),
        CameraControl(
            "brightness",
            "Brightness",
            0,
            255,
            128,
            apply_prop(cv2.CAP_PROP_BRIGHTNESS),
            read_prop(cv2.CAP_PROP_BRIGHTNESS),
        ),
        CameraControl(
            "contrast",
            "Contrast",
            0,
            255,
            128,
            apply_prop(cv2.CAP_PROP_CONTRAST),
            read_prop(cv2.CAP_PROP_CONTRAST),
        ),
        CameraControl(
            "saturation",
            "Saturation",
            0,
            255,
            128,
            apply_prop(cv2.CAP_PROP_SATURATION),
            read_prop(cv2.CAP_PROP_SATURATION),
        ),
        CameraControl(
            "sharpness",
            "Sharpness",
            0,
            255,
            128,
            apply_prop(cv2.CAP_PROP_SHARPNESS),
            read_prop(cv2.CAP_PROP_SHARPNESS),
        ),
    ]

    cv2.namedWindow(WINDOW, cv2.WINDOW_NORMAL)
    cv2.resizeWindow(WINDOW, 1280, 720)

    for ctrl in controls:
        profile_value = device_profile.get("controls", {}).get(ctrl.name)
        value = int(profile_value) if profile_value is not None else ctrl.default_value
        if profile_value is None and ctrl.read_fn is not None:
            try:
                value = ctrl.read_fn(cap)
            except Exception:
                value = ctrl.default_value
        value = clamp(value, ctrl.min_value, ctrl.max_value)
        cv2.createTrackbar(
            ctrl.trackbar,
            WINDOW,
            value - ctrl.min_value,
            ctrl.max_value - ctrl.min_value,
            lambda _v: None,
        )

    current_fps_idx = min(range(len(FPS_PRESETS)), key=lambda i: abs(FPS_PRESETS[i] - initial_fps))
    current_res_idx = min(
        range(len(RESOLUTION_PRESETS)),
        key=lambda i: abs(RESOLUTION_PRESETS[i][0] - initial_width) + abs(RESOLUTION_PRESETS[i][1] - initial_height),
    )
    cv2.createTrackbar("Resolution Preset", WINDOW, current_res_idx, len(RESOLUTION_PRESETS) - 1, lambda _v: None)
    cv2.createTrackbar("FPS Preset", WINDOW, current_fps_idx, len(FPS_PRESETS) - 1, lambda _v: None)

    status_text = f"Loaded persistent profile: {os.fspath(profile_path)}"
    applied_values: dict[str, int] = {}
    last_saved_state: tuple | None = None

    while True:
        res_idx = cv2.getTrackbarPos("Resolution Preset", WINDOW)
        fps_idx = cv2.getTrackbarPos("FPS Preset", WINDOW)
        if res_idx != current_res_idx:
            current_res_idx = res_idx
            w, h = RESOLUTION_PRESETS[current_res_idx]
            cap.set(cv2.CAP_PROP_FRAME_WIDTH, float(w))
            cap.set(cv2.CAP_PROP_FRAME_HEIGHT, float(h))
            status_text = f"Resolution set to {w}x{h}"
        if fps_idx != current_fps_idx:
            current_fps_idx = fps_idx
            fps = FPS_PRESETS[current_fps_idx]
            cap.set(cv2.CAP_PROP_FPS, float(fps))
            status_text = f"FPS set to {fps}"

        for ctrl in controls:
            pos = cv2.getTrackbarPos(ctrl.trackbar, WINDOW)
            raw_value = pos + ctrl.min_value
            applied_values[ctrl.name] = raw_value
            ctrl.apply_fn(cap, raw_value)

        ok, frame = cap.read()
        if not ok:
            status_text = "Camera frame read failed"
            if np is None:
                break
            frame = 255 * np.ones((480, 640, 3), dtype=np.uint8)

        width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        fps_actual = cap.get(cv2.CAP_PROP_FPS)
        selected_width, selected_height = RESOLUTION_PRESETS[current_res_idx]
        selected_fps = FPS_PRESETS[current_fps_idx]

        current_state = (
            selected_width,
            selected_height,
            selected_fps,
            tuple((k, applied_values[k]) for k in sorted(applied_values.keys())),
        )
        if current_state != last_saved_state:
            profile_data.setdefault("version", 1)
            profile_data.setdefault("profiles", {})
            profile_data["profiles"][device_key] = {
                "width": selected_width,
                "height": selected_height,
                "fps": selected_fps,
                "controls": {k: int(v) for k, v in applied_values.items()},
            }
            save_profile(profile_path, profile_data)
            last_saved_state = current_state
            status_text = f"Auto-saved profile: {os.fspath(profile_path)}"

        overlay_lines = [
            f"Device: {args.device}",
            f"Capture: {width}x{height} @ {fps_actual:.1f} fps",
            "Keys: [s] save YAML snapshot, [q]/[esc] quit",
            f"Status: {status_text}",
        ]

        y = 24
        for line in overlay_lines:
            cv2.putText(frame, line, (10, y), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2, cv2.LINE_AA)
            y += 26

        cv2.imshow(WINDOW, frame)
        key = cv2.waitKey(1) & 0xFF

        if key in (27, ord("q")):
            break
        if key == ord("s"):
            width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
            height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
            fps = int(round(cap.get(cv2.CAP_PROP_FPS)))
            save_yaml(save_path, args.device, width, height, fps, applied_values)
            status_text = f"Saved YAML snapshot: {os.fspath(save_path)}"

    cap.release()
    cv2.destroyAllWindows()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
