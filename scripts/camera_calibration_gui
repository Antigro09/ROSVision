#!/usr/bin/env python3
"""
Styled PhotonVision-like quick camera calibration dashboard.

- Competition-day camera tuning (exposure/resolution/etc.)
- Persistent profile autosave/autoload across reboots
- Team number + camera nickname configuration
- 3D AprilTag output placeholder table fields
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Callable, Optional

try:
    import cv2
except ImportError as exc:  # pragma: no cover
    print("ERROR: OpenCV Python bindings are required (python3-opencv).", file=sys.stderr)
    raise SystemExit(1) from exc

try:
    import numpy as np
except ImportError as exc:  # pragma: no cover
    print("ERROR: numpy is required.", file=sys.stderr)
    raise SystemExit(1) from exc


WINDOW = "ROSVision PhotonVision-Style Camera Dashboard"
DASHBOARD_W = 1600
DASHBOARD_H = 900
CONTROL_H = 560
CONTROL_Y = DASHBOARD_H - CONTROL_H

PIPELINE_TYPES = ["AprilTag"]
PROCESSING_MODES = ["2D", "3D"]
STREAM_DISPLAYS = ["Processed Stream View", "Raw Stream View"]
ORIENTATIONS = ["Normal", "Rotate 90 CW", "Rotate 90 CCW", "Rotate 180"]
CAMERA_TYPES = ["Generic", "OV9281"]

RESOLUTION_PRESETS = [
    (640, 480),
    (960, 540),
    (1280, 720),
    (1280, 800),  # requested competition default for OV9281 example
    (1920, 1080),
]
FPS_PRESETS = [15, 30, 60, 90, 120]
STREAM_RES_PRESETS = [(640, 400), (960, 600), (1280, 800), (1920, 1080)]


def clamp(value: int, lo: int, hi: int) -> int:
    return max(lo, min(hi, value))


def nearest_index(values: list[int], target: int) -> int:
    return min(range(len(values)), key=lambda i: abs(values[i] - target))


def nearest_resolution_index(values: list[tuple[int, int]], target_w: int, target_h: int) -> int:
    return min(range(len(values)), key=lambda i: abs(values[i][0] - target_w) + abs(values[i][1] - target_h))


@dataclass
class CameraControl:
    name: str
    trackbar: str
    min_value: int
    max_value: int
    default_value: int
    apply_fn: Callable[[cv2.VideoCapture, int], bool]
    read_fn: Optional[Callable[[cv2.VideoCapture], int]] = None


def apply_prop(prop: int, transform: Callable[[int], float] | None = None) -> Callable[[cv2.VideoCapture, int], bool]:
    def _apply(cap: cv2.VideoCapture, value: int) -> bool:
        out = float(transform(value) if transform else value)
        return bool(cap.set(prop, out))

    return _apply


def read_prop(prop: int, transform: Callable[[float], int] | None = None) -> Callable[[cv2.VideoCapture], int]:
    def _read(cap: cv2.VideoCapture) -> int:
        raw = cap.get(prop)
        return int(transform(raw) if transform else round(raw))

    return _read


def parse_device(device: str) -> int | str:
    return int(device) if device.isdigit() else device


def load_profile(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def save_profile(path: Path, profile: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(profile, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def save_yaml(path: Path, device: str, config: dict, controls: dict[str, int]) -> None:
    timestamp = dt.datetime.now().isoformat(timespec="seconds")
    lines = [
        f"# Generated by ROSVision camera_calibration_gui on {timestamp}",
        "camera:",
        f"  device: \"{device}\"",
        f"  nickname: \"{config['camera_nickname']}\"",
        f"  team_number: {config['team_number']}",
        f"  width: {config['capture_width']}",
        f"  height: {config['capture_height']}",
        f"  fps: {config['capture_fps']}",
        f"  pipeline_type: \"{PIPELINE_TYPES[config['pipeline_type_idx']]}\"",
        f"  processing_mode: \"{PROCESSING_MODES[config['processing_mode_idx']]}\"",
        f"  decimate: {config['decimate']}",
        f"  multitag_enabled: {str(bool(config['multitag_enabled'])).lower()}",
        f"  camera_type: \"{CAMERA_TYPES[config['camera_type_idx']]}\"",
    ]
    for k in (
        "auto_exposure",
        "exposure",
        "brightness",
        "gain",
        "red_awb_gain",
        "blue_awb_gain",
        "auto_white_balance",
        "white_balance_temperature",
        "low_latency_mode",
    ):
        if k in controls:
            lines.append(f"  {k}: {controls[k]}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def get_capture_settings(cap: cv2.VideoCapture) -> tuple[int, int, float]:
    return int(cap.get(cv2.CAP_PROP_FRAME_WIDTH)), int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT)), cap.get(cv2.CAP_PROP_FPS)


def put_line(img: np.ndarray, text: str, x: int, y: int, scale: float = 0.52, color: tuple[int, int, int] = (225, 235, 245)) -> None:
    cv2.putText(img, text, (x, y), cv2.FONT_HERSHEY_SIMPLEX, scale, color, 1, cv2.LINE_AA)


def draw_panel(img: np.ndarray, x: int, y: int, w: int, h: int, title: str) -> None:
    cv2.rectangle(img, (x, y), (x + w, y + h), (60, 78, 96), 1)
    cv2.rectangle(img, (x, y), (x + w, y + 30), (35, 52, 69), -1)
    put_line(img, title, x + 10, y + 20, 0.55, (245, 250, 255))


def draw_dashboard(
    frame: np.ndarray,
    config: dict,
    controls: dict[str, int],
    fps_actual: float,
    latency_ms: float,
    status_text: str,
    mode3d_rows: list[dict],
) -> np.ndarray:
    canvas = np.zeros((DASHBOARD_H, DASHBOARD_W, 3), dtype=np.uint8)
    canvas[:, :] = (22, 28, 34)

    # Header strip
    cv2.rectangle(canvas, (0, 0), (DASHBOARD_W, 58), (18, 24, 30), -1)
    put_line(canvas, "Cameras", 14, 35, 0.75, (255, 255, 255))
    put_line(canvas, f"{fps_actual:.1f} FPS", 180, 35, 0.6, (150, 230, 150))
    put_line(canvas, f"{latency_ms:.1f} ms latency", 295, 35, 0.6, (200, 220, 255))
    put_line(canvas, f"Team #{config['team_number']}", 510, 35, 0.6, (245, 245, 180))
    put_line(canvas, f"Status: {status_text}", 690, 35, 0.5, (255, 210, 160))

    # Stream region
    stream_x, stream_y, stream_w, stream_h = 16, 70, 1020, 580
    draw_panel(canvas, stream_x, stream_y, stream_w, stream_h, STREAM_DISPLAYS[config["stream_display_idx"]])

    frame_h, frame_w = frame.shape[:2]
    scale = min((stream_w - 16) / max(1, frame_w), (stream_h - 46) / max(1, frame_h))
    resized = cv2.resize(frame, (max(1, int(frame_w * scale)), max(1, int(frame_h * scale))))
    off_x = stream_x + 8 + ((stream_w - 16) - resized.shape[1]) // 2
    off_y = stream_y + 34 + ((stream_h - 44) - resized.shape[0]) // 2
    canvas[off_y : off_y + resized.shape[0], off_x : off_x + resized.shape[1]] = resized

    # Right side info panels
    panel_x = 1050
    draw_panel(canvas, panel_x, 70, 535, 180, "Camera")
    put_line(canvas, f"Nickname: {config['camera_nickname']}", panel_x + 14, 108)
    put_line(canvas, f"Device: {config['device_label']}", panel_x + 14, 132)
    put_line(canvas, f"Camera Type: {CAMERA_TYPES[config['camera_type_idx']]}", panel_x + 14, 156)
    put_line(canvas, f"Resolution: {config['capture_width']}x{config['capture_height']} @ {config['capture_fps']} FPS", panel_x + 14, 180)
    put_line(canvas, f"Stream Resolution: {config['stream_width']}x{config['stream_height']}", panel_x + 14, 204)

    draw_panel(canvas, panel_x, 260, 535, 220, "Pipeline")
    put_line(canvas, f"Pipeline: {config['pipeline_index']}", panel_x + 14, 298)
    put_line(canvas, f"Type: {PIPELINE_TYPES[config['pipeline_type_idx']]}", panel_x + 14, 322)
    put_line(canvas, f"Processing Mode: {PROCESSING_MODES[config['processing_mode_idx']]}", panel_x + 14, 346)
    put_line(canvas, f"Decimate: {config['decimate']}", panel_x + 14, 370)
    put_line(canvas, f"Enable MultiTag: {'ON' if config['multitag_enabled'] else 'OFF'}", panel_x + 14, 394)
    put_line(canvas, f"Orientation: {ORIENTATIONS[config['orientation_idx']]}", panel_x + 14, 418)
    put_line(canvas, f"Low Latency Mode: {'ON' if controls.get('low_latency_mode', 0) else 'OFF'}", panel_x + 14, 442)
    put_line(canvas, "Auto/Manual values use control sliders below.", panel_x + 14, 466, 0.46, (180, 200, 220))

    draw_panel(canvas, panel_x, 490, 535, 160, "3D Mode Output")
    put_line(canvas, "ID    X-meters    Y-meters    Z-angle theta    Ambiguity", panel_x + 12, 524, 0.44, (210, 235, 255))
    row_y = 548
    for row in mode3d_rows[:4]:
        put_line(
            canvas,
            f"{row['id']:>2}    {row['x']:>7.3f}      {row['y']:>7.3f}        {row['theta']:>7.2f} deg      {row['ambiguity']:>5.3f}",
            panel_x + 12,
            row_y,
            0.43,
            (235, 235, 235),
        )
        row_y += 24

    # Footer text for settings names requested
    put_line(
        canvas,
        "Settings shown: Team Number, Camera Nickname, Pipeline/AprilTag, Exposure, Brightness, Camera Gain, Red/Blue AWB, Auto WB, WB Temp, Orientation, Resolution, Stream Resolution",
        16,
        DASHBOARD_H - 14,
        0.42,
        (180, 200, 210),
    )
    return canvas


def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="ROSVision styled camera calibration dashboard")
    p.add_argument("--device", default="0", help="Camera index or /dev/video path")
    p.add_argument("--width", type=int, default=1280, help="Initial capture width")
    p.add_argument("--height", type=int, default=800, help="Initial capture height")
    p.add_argument("--fps", type=int, default=30, help="Initial capture FPS")
    p.add_argument("--team-number", type=int, default=0, help="WPILib/PhotonVision team number")
    p.add_argument("--camera-nickname", default="Placeholder Camera", help="Camera nickname")
    p.add_argument("--save-path", default="camera_calibration.yaml", help="YAML export path for 's' key")
    p.add_argument(
        "--profile-path",
        default="~/.config/rosvision/camera_calibration_profile.json",
        help="Persistent autosave profile path",
    )
    return p


def main() -> int:
    args = build_arg_parser().parse_args()
    save_path = Path(args.save_path).expanduser().resolve()
    profile_path = Path(args.profile_path).expanduser().resolve()

    device_key = str(args.device)
    profile_data = load_profile(profile_path)
    device_profile = profile_data.get("profiles", {}).get(device_key, {})

    cap = cv2.VideoCapture(parse_device(args.device), cv2.CAP_V4L2)
    if not cap.isOpened():
        cap = cv2.VideoCapture(parse_device(args.device))
    if not cap.isOpened():
        print(f"ERROR: Could not open camera device '{args.device}'", file=sys.stderr)
        return 1

    # Requested competition defaults for OV9281 + AprilTag guidance.
    initial_width = int(device_profile.get("capture_width", args.width))
    initial_height = int(device_profile.get("capture_height", args.height))
    initial_fps = int(device_profile.get("capture_fps", args.fps))
    cap.set(cv2.CAP_PROP_FRAME_WIDTH, float(initial_width))
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, float(initial_height))
    cap.set(cv2.CAP_PROP_FPS, float(initial_fps))

    controls: list[CameraControl] = [
        CameraControl(
            "auto_exposure",
            "Auto Exposure",
            0,
            1,
            int(device_profile.get("controls", {}).get("auto_exposure", 0)),
            apply_prop(cv2.CAP_PROP_AUTO_EXPOSURE, lambda v: 0.75 if v else 0.25),
            read_prop(cv2.CAP_PROP_AUTO_EXPOSURE, lambda v: 1 if v >= 0.5 else 0),
        ),
        CameraControl(
            "exposure",
            "Exposure",
            -13,
            1,
            int(device_profile.get("controls", {}).get("exposure", -6)),
            apply_prop(cv2.CAP_PROP_EXPOSURE),
            read_prop(cv2.CAP_PROP_EXPOSURE),
        ),
        CameraControl(
            "brightness",
            "Brightness",
            0,
            100,
            int(device_profile.get("controls", {}).get("brightness", 50)),
            apply_prop(cv2.CAP_PROP_BRIGHTNESS, lambda v: v / 100.0),
        ),
        CameraControl(
            "gain",
            "Camera Gain",
            0,
            255,
            int(device_profile.get("controls", {}).get("gain", 75)),
            apply_prop(cv2.CAP_PROP_GAIN),
            read_prop(cv2.CAP_PROP_GAIN),
        ),
        CameraControl(
            "red_awb_gain",
            "Red AWB Gain",
            0,
            40,
            int(device_profile.get("controls", {}).get("red_awb_gain", 11)),
            apply_prop(cv2.CAP_PROP_WHITE_BALANCE_RED_V, lambda v: float(v * 100)),
        ),
        CameraControl(
            "blue_awb_gain",
            "Blue AWB Gain",
            0,
            40,
            int(device_profile.get("controls", {}).get("blue_awb_gain", 20)),
            apply_prop(cv2.CAP_PROP_WHITE_BALANCE_BLUE_U, lambda v: float(v * 100)),
        ),
        CameraControl(
            "auto_white_balance",
            "Auto White Balance",
            0,
            1,
            int(device_profile.get("controls", {}).get("auto_white_balance", 1)),
            apply_prop(cv2.CAP_PROP_AUTO_WB),
        ),
        CameraControl(
            "white_balance_temperature",
            "White Balance Temperature",
            2500,
            7500,
            int(device_profile.get("controls", {}).get("white_balance_temperature", 4000)),
            apply_prop(cv2.CAP_PROP_WB_TEMPERATURE),
        ),
        CameraControl(
            "low_latency_mode",
            "Low Latency Mode",
            0,
            1,
            int(device_profile.get("controls", {}).get("low_latency_mode", 1)),
            apply_prop(cv2.CAP_PROP_BUFFERSIZE, lambda v: 1.0 if v else 4.0),
        ),
    ]

    cv2.namedWindow(WINDOW, cv2.WINDOW_NORMAL)
    cv2.resizeWindow(WINDOW, DASHBOARD_W, DASHBOARD_H)

    for ctrl in controls:
        val = clamp(ctrl.default_value, ctrl.min_value, ctrl.max_value)
        cv2.createTrackbar(ctrl.trackbar, WINDOW, val - ctrl.min_value, ctrl.max_value - ctrl.min_value, lambda _v: None)

    # Meta/settings trackbars
    team_default = int(device_profile.get("team_number", args.team_number))
    decimate_default = int(device_profile.get("decimate", 2))
    cam_type_default = int(device_profile.get("camera_type_idx", 1))  # OV9281 requested default
    mode_default = int(device_profile.get("processing_mode_idx", 1))  # 3D requested default
    multitag_default = int(device_profile.get("multitag_enabled", 1))  # enabled default
    orientation_default = int(device_profile.get("orientation_idx", 0))
    pipeline_idx_default = int(device_profile.get("pipeline_index", 0))

    cv2.createTrackbar("Team Number", WINDOW, clamp(team_default, 0, 9999), 9999, lambda _v: None)
    cv2.createTrackbar("Pipeline", WINDOW, clamp(pipeline_idx_default, 0, 9), 9, lambda _v: None)
    cv2.createTrackbar("Type", WINDOW, 0, len(PIPELINE_TYPES) - 1, lambda _v: None)
    cv2.createTrackbar("Processing Mode", WINDOW, clamp(mode_default, 0, len(PROCESSING_MODES) - 1), len(PROCESSING_MODES) - 1, lambda _v: None)
    cv2.createTrackbar("Decimate", WINDOW, clamp(decimate_default, 1, 4), 4, lambda _v: None)
    cv2.createTrackbar("Enable MultiTag", WINDOW, clamp(multitag_default, 0, 1), 1, lambda _v: None)
    cv2.createTrackbar("Camera Type", WINDOW, clamp(cam_type_default, 0, len(CAMERA_TYPES) - 1), len(CAMERA_TYPES) - 1, lambda _v: None)
    cv2.createTrackbar("Orientation", WINDOW, clamp(orientation_default, 0, len(ORIENTATIONS) - 1), len(ORIENTATIONS) - 1, lambda _v: None)
    cv2.createTrackbar("Stream Display", WINDOW, int(device_profile.get("stream_display_idx", 0)), len(STREAM_DISPLAYS) - 1, lambda _v: None)

    # Resolution/fps controls with requested example defaults
    initial_res_idx = nearest_resolution_index(RESOLUTION_PRESETS, initial_width, initial_height)
    initial_fps_idx = nearest_index(FPS_PRESETS, initial_fps)
    initial_stream_res_idx = nearest_resolution_index(
        STREAM_RES_PRESETS,
        int(device_profile.get("stream_width", initial_width)),
        int(device_profile.get("stream_height", initial_height)),
    )
    cv2.createTrackbar("Resolution", WINDOW, initial_res_idx, len(RESOLUTION_PRESETS) - 1, lambda _v: None)
    cv2.createTrackbar("Capture FPS", WINDOW, initial_fps_idx, len(FPS_PRESETS) - 1, lambda _v: None)
    cv2.createTrackbar("Stream Resolution", WINDOW, initial_stream_res_idx, len(STREAM_RES_PRESETS) - 1, lambda _v: None)

    current_res_idx = initial_res_idx
    current_fps_idx = initial_fps_idx
    current_stream_res_idx = initial_stream_res_idx

    nickname_input = str(device_profile.get("camera_nickname", args.camera_nickname))
    status_text = "Ready (press n to rename camera, s to save YAML, q/esc to quit)"
    last_tick = cv2.getTickCount()
    last_saved_state = None

    while True:
        now_tick = cv2.getTickCount()
        dt_ms = (now_tick - last_tick) * 1000.0 / cv2.getTickFrequency()
        last_tick = now_tick

        # Resolution + FPS updates
        r_idx = cv2.getTrackbarPos("Resolution", WINDOW)
        f_idx = cv2.getTrackbarPos("Capture FPS", WINDOW)
        s_idx = cv2.getTrackbarPos("Stream Resolution", WINDOW)
        if r_idx != current_res_idx:
            current_res_idx = r_idx
            w, h = RESOLUTION_PRESETS[current_res_idx]
            cap.set(cv2.CAP_PROP_FRAME_WIDTH, float(w))
            cap.set(cv2.CAP_PROP_FRAME_HEIGHT, float(h))
            status_text = f"Capture resolution set to {w}x{h}"
        if f_idx != current_fps_idx:
            current_fps_idx = f_idx
            fps = FPS_PRESETS[current_fps_idx]
            cap.set(cv2.CAP_PROP_FPS, float(fps))
            status_text = f"Capture FPS set to {fps}"
        if s_idx != current_stream_res_idx:
            current_stream_res_idx = s_idx
            sw, sh = STREAM_RES_PRESETS[current_stream_res_idx]
            status_text = f"Stream resolution set to {sw}x{sh}"

        control_values: dict[str, int] = {}
        for ctrl in controls:
            pos = cv2.getTrackbarPos(ctrl.trackbar, WINDOW)
            raw = pos + ctrl.min_value
            control_values[ctrl.name] = raw
            ctrl.apply_fn(cap, raw)

        ok, frame = cap.read()
        if not ok:
            sel_w, sel_h = RESOLUTION_PRESETS[current_res_idx]
            frame = np.ones((max(1, sel_h), max(1, sel_w), 3), dtype=np.uint8) * 255
            status_text = "Camera frame read failed; showing fallback frame"

        cap_w, cap_h, cap_fps = get_capture_settings(cap)
        stream_w, stream_h = STREAM_RES_PRESETS[current_stream_res_idx]
        mode_idx = cv2.getTrackbarPos("Processing Mode", WINDOW)

        config = {
            "team_number": cv2.getTrackbarPos("Team Number", WINDOW),
            "camera_nickname": nickname_input,
            "device_label": str(args.device),
            "pipeline_index": cv2.getTrackbarPos("Pipeline", WINDOW),
            "pipeline_type_idx": cv2.getTrackbarPos("Type", WINDOW),
            "processing_mode_idx": mode_idx,
            "decimate": max(1, cv2.getTrackbarPos("Decimate", WINDOW)),
            "multitag_enabled": cv2.getTrackbarPos("Enable MultiTag", WINDOW),
            "camera_type_idx": cv2.getTrackbarPos("Camera Type", WINDOW),
            "orientation_idx": cv2.getTrackbarPos("Orientation", WINDOW),
            "stream_display_idx": cv2.getTrackbarPos("Stream Display", WINDOW),
            "capture_width": cap_w,
            "capture_height": cap_h,
            "capture_fps": FPS_PRESETS[current_fps_idx],
            "stream_width": stream_w,
            "stream_height": stream_h,
        }

        # Placeholder 3D rows requested for mode output
        mode3d_rows = []
        if mode_idx == 1:
            mode3d_rows = [
                {"id": 1, "x": 0.000, "y": 0.000, "theta": 0.0, "ambiguity": 0.000},
                {"id": 2, "x": 0.000, "y": 0.000, "theta": 0.0, "ambiguity": 0.000},
            ]

        dashboard = draw_dashboard(
            frame=frame,
            config=config,
            controls=control_values,
            fps_actual=cap_fps,
            latency_ms=dt_ms,
            status_text=status_text,
            mode3d_rows=mode3d_rows,
        )
        cv2.imshow(WINDOW, dashboard)

        current_state = (
            tuple(sorted((k, int(v)) for k, v in control_values.items())),
            tuple(sorted((k, int(v)) for k, v in config.items() if isinstance(v, int))),
            str(config["camera_nickname"]),
        )
        if current_state != last_saved_state:
            profile_data.setdefault("version", 1)
            profile_data.setdefault("profiles", {})
            profile_data["profiles"][device_key] = {**config, "controls": control_values}
            save_profile(profile_path, profile_data)
            last_saved_state = current_state

        key = cv2.waitKey(1) & 0xFF
        if key in (27, ord("q")):
            break
        if key == ord("s"):
            save_yaml(save_path, args.device, config, control_values)
            status_text = f"Saved YAML snapshot: {os.fspath(save_path)}"
        if key == ord("n"):
            entered = input("Enter camera nickname: ").strip()
            if entered:
                nickname_input = entered
                status_text = f"Camera nickname set to '{nickname_input}'"

    cap.release()
    cv2.destroyAllWindows()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
